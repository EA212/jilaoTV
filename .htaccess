RewriteEngine On

# ==================== 浏览器缓存配置 ====================
<IfModule mod_expires.c>
    ExpiresActive On
    
    # HTML：2.5小时（与localStorage缓存同步）
    ExpiresByType text/html "access plus 2 hours 30 minutes"
    
    # CSS：1年（使用版本号控制更新）
    ExpiresByType text/css "access plus 1 year"
    
    # JavaScript：1年（使用版本号控制更新）
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    
    # 图片：1年（使用版本号控制更新）
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # 字体：1年
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    
    # manifest.json：1天
    ExpiresByType application/manifest+json "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
    # HTML：短期缓存，需要验证
    <FilesMatch "\.(html)$">
        Header set Cache-Control "public, max-age=9000, must-revalidate"
    </FilesMatch>
    
    # 静态资源（CSS、JS、图片、字体）：长期缓存
    <FilesMatch "\.(css|js|jpg|jpeg|png|gif|webp|ico|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # manifest.json：短期缓存
    <FilesMatch "manifest\.json$">
        Header set Cache-Control "public, max-age=86400"
    </FilesMatch>
    
    # service-worker.js：不缓存（总是获取最新版本）
    <FilesMatch "service-worker\.js$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </FilesMatch>
    
    # api.php：不缓存（总是获取最新数据）
    <FilesMatch "api\.php$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </FilesMatch>
</IfModule>
# ==================== 缓存配置结束 ====================

# Route /admin to admin/index.html
RewriteRule ^admin$ admin/index.html [L]
RewriteRule ^admin/$ admin/index.html [L]

# Route all /api/* requests to api.php
RewriteCond %{REQUEST_URI} ^/api/
RewriteRule ^api/(.*)$ api.php [L,QSA]

# Serve existing files normally
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Fallback to index.html for SPA
RewriteRule ^ index.html [L]
